-- tabla carrera
create table tcarrera (
    codcarrera char(5) primary key,
    carrera varchar2(50)
);

-- tabla usuario 
create table tusuario (
    usuario char(5) primary key,
    contrasena char(5)
);

-- tabla asignatura
-- nota: codrequisito es una clave foránea recursiva
create table tasignatura (
    codasignatura char(5) primary key,
    asignatura varchar2(50),
    codrequisito char(5),
    constraint fk_requisito foreign key (codrequisito) references tasignatura(codasignatura)
);

-- tabla alumno
create table talumno (
    codalumno char(5) primary key,
    apaterno varchar2(50),
    amaterno varchar2(50),
    nombres varchar2(50),
    usuario char(5) unique,
    codcarrera char(5),
    constraint fk_alu_usuario foreign key (usuario) references tusuario(usuario),
    constraint fk_alu_carrera foreign key (codcarrera) references tcarrera(codcarrera)
);

-- tabla docente
create table tdocente (
    coddocente char(5) primary key, -- corregido nombre para consistencia
    apaterno varchar2(50),
    amaterno varchar2(50),
    nombres varchar2(50),
    usuario char(5) unique,
    constraint fk_doc_usuario foreign key (usuario) references tusuario(usuario)
);

-- tabla carga
create table tcarga (
    idcarga int primary key,
    coddocente char(5),
    codasignatura char(5),
    semestre varchar2(50),
    constraint fk_car_docente foreign key (coddocente) references tdocente(coddocente),
    constraint fk_car_asignatura foreign key (codasignatura) references tasignatura(codasignatura)
);

-- tabla notas
create table tnotas (
    codalumno char(5),
    codasignatura char(5),
    semestre varchar2(50),
    parcial1 number(4,2), -- en oracle se prefiere number para decimales
    parcial2 number(4,2),
    notafinal number(4,2),
    primary key (codalumno, codasignatura, semestre),
    constraint fk_not_alumno foreign key (codalumno) references talumno(codalumno),
    constraint fk_not_asignatura foreign key (codasignatura) references tasignatura(codasignatura)
);

