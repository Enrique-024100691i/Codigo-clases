-- Relacion de alumnos que estudian sistemas
select a.*
from tcarrera c
join talumno a on c.codcarrera = a.codcarrera
where c.carrera = 'Sistemas';

-- Relacion de coente con su respectiva Carga
select 
    d.apaterno, 
    d.amaterno, 
    d.nombres, 
    asig.asignatura, 
    car.semestre
from tdocente d
join tcarga car on d.coddocente = car.coddocente
join tasignatura asig on car.codasignatura = asig.codasignatura;

-- Ficha de seguimineto
select 
    alu.apaterno, 
    alu.amaterno, 
    alu.nombres,
    asig.asignatura,
    n.notafinal,
    case 
        when n.notafinal >= 13.5 then 'aprobado'
        else 'desaprobado'
    end as estado,
    n.semestre
from talumno alu
join tnotas n on alu.codalumno = n.codalumno
join tasignatura asig on n.codasignatura = asig.codasignatura
where alu.codalumno = 'A0001';
